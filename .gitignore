# Build outputs
bin/
frontend/dist/*
!frontend/dist/.gitkeep
frontend/node_modules/
frontend/*.tsbuildinfo

# Go test artifacts
*.test
coverage*.out
coverage*.html

# Generated binaries (root-anchored so cmd/lgb/ and cmd/plcsim/ source dirs are NOT ignored)
/lgb
/lgb-*
/plcsim
/plcsim-*

# Local data and backups
data/
backups/
*.db
*.db-journal
*.db-wal
*.db-shm

# Secrets and local config
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.crt
!ca.crt

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
logs/

# Engram / SDD local artifacts that should not be committed
.engram/
.atl/cache/
