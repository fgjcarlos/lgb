# docker/.env.dev.example — required environment variables for docker-compose.dev.yml
#
# Copy this file to docker/.env.dev (or export the variables in your shell)
# and fill in real values before running `make docker-up`.
#
# NEVER commit the actual docker/.env.dev file — it contains secrets.
# Add docker/.env.dev to .gitignore if it does not already appear there.
#
# The dev stack requires this variable at minimum:

# JWT signing key used by the gateway. Required — set a value before running.
# Generate one with: openssl rand -hex 32
# Do NOT commit the filled-in copy. Do NOT reuse any test value in production.
LGB_AUTH_JWT_SECRET=
