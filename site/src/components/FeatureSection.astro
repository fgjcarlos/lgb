---
interface Feature {
  title: string;
  body: string;
}

interface Props {
  label: string;
  items: Feature[];
}

const { label, items } = Astro.props;
---

<div>
  <p class="text-xs font-semibold uppercase tracking-[0.3em] text-amber-300">{label}</p>
  <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {
      items.map((item) => (
        <article class="rounded-3xl border border-white/10 bg-white/[0.04] p-6 transition hover:border-amber-300/30 hover:bg-white/[0.07]">
          <h3 class="text-lg font-semibold text-white">{item.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-slate-300">{item.body}</p>
        </article>
      ))
    }
  </div>
</div>
