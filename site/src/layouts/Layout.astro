---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const ogTitle = title;
const ogDescription = description;
const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://fgjcarlos.github.io/lgb").toString();
---

<!doctype html>
<html lang="en" class="bg-slate-950 text-slate-100">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
  </head>
  <body class="min-h-screen bg-[radial-gradient(circle_at_top,#6b3a1f_0%,#0f172a_38%,#020617_100%)] antialiased">
    <slot />
  </body>
</html>
